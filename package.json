{
  "name": "sharkord-vid-with-friends",
  "version": "0.0.1",
  "module": "src/index.ts",
  "sharkord": {
    "entry": {
      "server": "index.js",
      "client": "index.js"
    },
    "author": "Vid with Friends Team",
    "homepage": "https://github.com/popoboxxo/sharkord-vid-with-friends",
    "description": "A plugin that allows users to watch YouTube videos together in sync within Sharkord voice channels",
    "logo": "https://i.imgur.com/placeholder.png"
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist/sharkord-vid-with-friends --target bun --minify --format esm && bun run scripts/write-dist-package.ts && mkdir -p dist/sharkord-vid-with-friends/bin",
    "build:dev": "bun run build",
    "dev:stack": "bun run scripts/dev-stack.ts",
    "dev:reload": "bun run scripts/dev-stack.ts reload",
    "dev:stack:fresh": "bun run scripts/dev-stack.ts fresh",
    "test": "bun test",
    "test:unit": "bun test tests/unit/",
    "test:integration": "bun test tests/integration/",
    "test:docker": "docker compose -f tests/docker/docker-compose.yml up --build --abort-on-container-exit",
    "session:start": "bun run build && bun test",
    "session:dev": "bun run build && bun test && echo '--- Session ready for development ---'",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "react": "^19.2.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
